# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b-cloud

# --- Backend ---
MAX_UPLOAD_MB=50
PROJECTS_DIR=./reviewer_projects
REQUEST_TIMEOUT_SECONDS=300
MAX_FILES_PER_PROJECT=200
MAX_FILE_SIZE_KB=300

# "grep" = code-index-mcp (no setup needed), "semantic" = cocoindex-code
# (needs `uv tool install --force "cocoindex-code[full]"` installed separately)
CODE_INDEX_BACKEND=semantic

# When true, prints every MCP and Ollama request/response verbatim to stdout
TRACE_IO=false

# --- History database + GitHub fetching ---
DB_PATH=./reviewer_projects/history.db
# Optional: raises the unauthenticated 60 req/hr GitHub API rate limit if you hit it
GITHUB_TOKEN=your_github_token_here

# --- Frontend / CLI ---
REVIEWER_API_URL=http://localhost:8000
